<Window
  x:Class="ImageProcessor.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="clr-namespace:ImageProcessor.ViewModels"
  xmlns:conv="clr-namespace:ImageProcessor.Converters"
  Title="Сепия-обработчик изображений"
  Width="1100"
  Height="720"
  MinWidth="900"
  MinHeight="600"
  Background="{StaticResource BackgroundBrush}"
  FontFamily="Segoe UI"
>
  <Window.DataContext>
    <vm:MainViewModel />
  </Window.DataContext>

  <Window.Resources>
    <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
  </Window.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <!-- Заголовок -->
      <RowDefinition Height="Auto" />
      <!-- Кнопки управления -->
      <RowDefinition Height="Auto" />
      <!-- Прогресс -->
      <RowDefinition Height="Auto" />
      <!-- Основной контент -->
      <RowDefinition Height="*" />
      <!-- Результаты сравнения -->
      <RowDefinition Height="Auto" />
      <!-- Статус-бар -->
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- ===== Заголовок ===== -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock
        Text="Обработка изображений"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontSize="22"
        FontWeight="Bold"
      />
      <TextBlock
        Text="Сравнение однопоточного и многопоточного режимов — сепия-фильтр"
        Style="{StaticResource CaptionText}"
        Margin="0,4,0,0"
      />
    </StackPanel>

    <!-- ===== Панель кнопок ===== -->
    <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
      <Button
        Content="📁  Загрузить изображения"
        Command="{Binding LoadImagesCommand}"
        Style="{StaticResource PrimaryButton}"
        Margin="0,0,10,0"
      />
      <Button
        Content="▶  Однопоточно"
        Command="{Binding RunSingleCommand}"
        Style="{StaticResource SecondaryButton}"
        Margin="0,0,10,0"
      />
      <Button
        Content="⚡  Многопоточно"
        Command="{Binding RunMultiCommand}"
        Style="{StaticResource SecondaryButton}"
        Margin="0,0,10,0"
      />
      <Button
        Content="✕  Очистить"
        Command="{Binding ClearCommand}"
        Style="{StaticResource SecondaryButton}"
      />
      <!-- Счётчик загруженных файлов -->
      <TextBlock VerticalAlignment="Center"
                 Margin="16,0,0,0"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="12">
                <Run Text="Загружено: "/>
                <Run Text="{Binding SourceImages.Count, Mode=OneWay}"
                     Foreground="{StaticResource AccentBrush}"/>
                <Run Text=" шт."/>
      </TextBlock>
    </WrapPanel>

    <!-- ===== Прогресс-бар (виден только во время обработки) ===== -->
    <StackPanel Grid.Row="2"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,16">
      <DockPanel Margin="0,0,0,6">
        <TextBlock DockPanel.Dock="Right"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11">
                    <Run Text="{Binding ProgressValue, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding ProgressMax, Mode=OneWay}"/>
        </TextBlock>
        <TextBlock Text="Обработка..."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11"/>
      </DockPanel>
      <ProgressBar Value="{Binding ProgressValue}"
                   Maximum="{Binding ProgressMax}"/>
    </StackPanel>

    <!-- ===== Три колонки с изображениями ===== -->
    <Grid Grid.Row="3"
          Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Исходные -->
      <Border Grid.Column="0"
              Style="{StaticResource Card}">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top"
                     Text="Исходные изображения"
                     Style="{StaticResource SectionHeader}"/>
          <ListBox ItemsSource="{Binding SourceImages}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Image Source="{Binding}"
                       Margin="0,4"
                       MaxHeight="150"
                       Stretch="Uniform"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Однопоточный результат -->
      <Border Grid.Column="2"
              Style="{StaticResource Card}">
        <DockPanel>
          <DockPanel DockPanel.Dock="Top"
                     Margin="0,0,0,10">
            <TextBlock Text="Однопоточный режим"
                       Style="{StaticResource SectionHeader}"
                       Margin="0"/>
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding SingleResultText}"
                       Style="{StaticResource ValueLabel}"
                       VerticalAlignment="Center"/>
          </DockPanel>
          <ListBox ItemsSource="{Binding SingleProcessedImages}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Image Source="{Binding}"
                       Margin="0,4"
                       MaxHeight="150"
                       Stretch="Uniform"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Многопоточный результат -->
      <Border Grid.Column="4"
              Style="{StaticResource Card}">
        <DockPanel>
          <DockPanel DockPanel.Dock="Top"
                     Margin="0,0,0,10">
            <TextBlock Text="Многопоточный режим"
                       Style="{StaticResource SectionHeader}"
                       Margin="0"/>
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding MultiResultText}"
                       Style="{StaticResource ValueLabel}"
                       VerticalAlignment="Center"/>
          </DockPanel>
          <ListBox ItemsSource="{Binding MultiProcessedImages}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Image Source="{Binding}"
                       Margin="0,4"
                       MaxHeight="150"
                       Stretch="Uniform"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
    </Grid>

    <!-- ===== Панель сравнения результатов (показывается когда оба прогона завершены) ===== -->
    <Border Grid.Row="4"
            Style="{StaticResource Card}"
            Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"
            Margin="0,0,0,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Однопоточный: время -->
        <StackPanel Grid.Column="0"
                    HorizontalAlignment="Center">
          <TextBlock Text="Однопоточный"
                     Style="{StaticResource CaptionText}"
                     HorizontalAlignment="Center"/>
          <TextBlock Style="{StaticResource ValueLabel}"
                     HorizontalAlignment="Center"
                     FontSize="20">
                        <Run Text="{Binding SingleResult.ElapsedMs, Mode=OneWay}"/>
                        <Run Text=" мс"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             FontSize="13"/>
          </TextBlock>
        </StackPanel>

        <!-- Многопоточный: время -->
        <StackPanel Grid.Column="1"
                    HorizontalAlignment="Center">
          <TextBlock Text="Многопоточный"
                     Style="{StaticResource CaptionText}"
                     HorizontalAlignment="Center"/>
          <TextBlock Style="{StaticResource ValueLabel}"
                     HorizontalAlignment="Center"
                     FontSize="20"
                     Foreground="{StaticResource SuccessBrush}">
                        <Run Text="{Binding MultiResult.ElapsedMs, Mode=OneWay}"/>
                        <Run Text=" мс"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             FontSize="13"/>
          </TextBlock>
        </StackPanel>

        <!-- Ускорение -->
        <StackPanel Grid.Column="2"
                    HorizontalAlignment="Center">
          <TextBlock Text="Ускорение"
                     Style="{StaticResource CaptionText}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="{Binding SpeedupText}"
                     Style="{StaticResource ValueLabel}"
                     HorizontalAlignment="Center"
                     FontSize="14"
                     TextWrapping="Wrap"
                     TextAlignment="Center"/>
        </StackPanel>

        <!-- Количество изображений -->
        <StackPanel Grid.Column="3"
                    HorizontalAlignment="Center">
          <TextBlock Text="Изображений"
                     Style="{StaticResource CaptionText}"
                     HorizontalAlignment="Center"/>
          <TextBlock Style="{StaticResource ValueLabel}"
                     HorizontalAlignment="Center"
                     FontSize="20">
                        <Run Text="{Binding SingleResult.ImageCount, Mode=OneWay}"/>
                        <Run Text=" шт."
                             Foreground="{StaticResource TextSecondaryBrush}"
                             FontSize="13"/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===== Статус-бар ===== -->
    <Border Grid.Row="5"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12,6">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="11"/>
    </Border>
  </Grid>
</Window>
